# Server
LISTEN_ADDR=127.0.0.1
LISTEN_PORT=8080
READ_TIMEOUT=12s
WRITE_TIMEOUT=15s
IDLE_TIMEOUT=20s

# Download Test
DOWNLOAD_BUFFER_SIZE=1ki          # Size of pre-generated random buffer 
DOWNLOAD_MAX_SIZE=10Mi            # Max allowed download size per request, 0 for none

# Upload Test
UPLOAD_MAX_SIZE=50

# Logging
LOG_LEVEL=info                    # debug, info, warn, error
LOG_FILE="speedtest.log"          # path to write log data```
